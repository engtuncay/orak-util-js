{
  "include": [
    "src",
    "src/**/*.test.ts"
  ],
  "exclude": [
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": [
      "vitest"
    ]
  }
}